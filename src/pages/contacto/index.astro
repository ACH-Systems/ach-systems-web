---
import { Mail, MapPin, Phone } from "@lucide/astro";
import { Instagram, LinkedIn, Telegram, WhatsApp } from "~assets/icons";
import { HeroSmall } from "~assets/img";
import { Layout } from "~components";
import {
  Article,
  Button,
  Box,
  Flex,
  Grid,
  Heading,
  Image,
  Paragraph,
  Section,
} from "~components/ui";
---

<Layout title="CONTACTO :: ACH SYSTEMS">
  <Section class="py-8 lg:py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <Heading class="text-3xl md:text-4xl lg:text-5xl text-center mb-8 lg:mb-16 font-bold uppercase text-accent"
        >Contáctanos</Heading
      >
      
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="order-2 lg:order-1">
          <Box class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 lg:p-8 shadow-xl border border-neutral-100">
            <Heading as="h2" class="text-xl lg:text-2xl font-bold mb-6 text-neutral-800"
              >Escríbenos</Heading
            >
            <form
              action="https://formspree.io/f/xkgbrojp"
              method="POST"
              class="flex flex-col gap-5"
            >
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="name"
                  >Nombre completo o empresa</label
                >
                <input
                  id="name"
                  name="Nombre completo o nombre de la empresa"
                  type="text"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all"
                  required
                  placeholder="Tu nombre o el de tu empresa"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="email"
                  >Correo electrónico</label
                >
                <input
                  id="email"
                  name="Correo electrónico"
                  type="email"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all"
                  required
                  placeholder="correo@ejemplo.com"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="phone"
                  >Número de teléfono</label
                >
                <input
                  id="phone"
                  name="Número de teléfono"
                  type="tel"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all"
                  required
                  placeholder="+58 412 123 4567"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-3"
                  >Motivo de contacto</label
                >
                <div class="flex flex-col gap-3">
                  {
                    [
                      "Sistema para Empresa Personal",
                      "Sistema de Gestión",
                      "Sistema Médico / Consultorio / Historias Médicas",
                      "Sistema Administrativo",
                      "Otro / Necesito Asesoría",
                    ].map((option, optionIndex) => {
                      const id = `motive-${optionIndex + 1}`;
                      return (
                        <label for={id} class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-neutral-50 transition-colors">
                          <input
                            type="radio"
                            name="Motivo de solicitud"
                            id={id}
                            value={option}
                            class="radio radio-sm radio-primary"
                          />
                          <span class="text-sm text-neutral-700">{option}</span>
                        </label>
                      );
                    })
                  }
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="message"
                  >Cuéntanos más sobre tu proyecto</label
                >
                <textarea
                  id="message"
                  name="Comentenos un poco más"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all h-32 resize-none"
                  placeholder="Describe brevemente tu necesidad..."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="btn bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-6 rounded-lg transition-all hover:shadow-lg hover:-translate-y-0.5"
              >
                Enviar mensaje
              </button>
            </form>
          </Box>
        </div>

        <div class="order-1 lg:order-2 flex flex-col gap-6">
          <Box class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 lg:p-8 shadow-xl border border-neutral-100">
            <Image
              src={HeroSmall}
              alt="ACH Systems - Contáctanos"
              loading="eager"
              class="w-full rounded-xl mb-6 shadow-md"
            />
            
            <Heading as="h2" class="text-xl lg:text-2xl font-bold mb-6 text-neutral-800"
              >Encuéntranos</Heading
            >
            
            <div class="flex flex-col gap-4">
              <a
                href={`https://wa.me/584246375061`}
                class="flex items-center gap-4 p-3 rounded-lg hover:bg-neutral-50 transition-colors group"
              >
                <div class="p-2 bg-[#128c7e] rounded-lg group-hover:scale-110 transition-transform">
                  <WhatsApp class="size-5 fill-white" />
                </div>
                <div>
                  <p class="font-semibold text-neutral-800">WhatsApp</p>
                  <p class="text-sm text-neutral-600">+58 424-637-5061</p>
                </div>
              </a>

              <a
                href="mailto:achsystems@hotmail.com"
                class="flex items-center gap-4 p-3 rounded-lg hover:bg-neutral-50 transition-colors group"
              >
                <div class="p-2 bg-neutral-600 rounded-lg group-hover:scale-110 transition-transform">
                  <Mail class="size-5 text-white" />
                </div>
                <div>
                  <p class="font-semibold text-neutral-800">Email</p>
                  <p class="text-sm text-neutral-600">achsystems@hotmail.com</p>
                </div>
              </a>
            </div>

            <div class="mt-6 pt-6 border-t border-neutral-200">
              <p class="font-semibold text-neutral-700 mb-4">Síguenos en redes sociales</p>
              <Grid class="grid-cols-4 gap-3">
                <a 
                  target="_blank" 
                  href="https://www.instagram.com/achsystems"
                  class="p-3 bg-gradient-to-tr from-yellow-500 via-pink-600 to-blue-500 rounded-lg flex justify-center hover:scale-110 transition-transform"
                >
                  <Instagram class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://wa.me/584246375061"
                  class="p-3 bg-[#128c7e] rounded-lg flex justify-center hover:scale-110 transition-transform"
                >
                  <WhatsApp class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://www.linkedin.com/in/ach-systems-2025-4146700191-/"
                  class="p-3 bg-[#0a66c2] rounded-lg flex justify-center hover:scale-110 transition-transform"
                >
                  <LinkedIn class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://t.me/achsystems"
                  class="p-3 bg-[#0088cc] rounded-lg flex justify-center hover:scale-110 transition-transform"
                >
                  <Telegram class="size-6 fill-white" />
                </a>
              </Grid>
            </div>
          </Box>
        </div>
      </div>
    </div>
  </Section>

  <Section class="bg-primary py-12 lg:py-16 text-white">
    <div class="max-w-4xl mx-auto text-center px-4">
      <Heading class="text-2xl md:text-3xl font-bold mb-4"
        >¿Necesitas una asesoría personalizada?</Heading
      >
      <Paragraph class="text-lg mb-6 text-white/80">
        Nuestro equipo está listo para evaluar tu proyecto sin compromiso
      </Paragraph>
      <a 
        href="https://wa.me/584246375061"
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-8 rounded-full transition-all hover:shadow-lg hover:-translate-y-0.5"
      >
        <WhatsApp class="size-5 fill-white" />
        Chatea con nosotros
      </a>
    </div>
  </Section>
</Layout>
