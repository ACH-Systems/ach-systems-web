---
import { Mail, MapPin, Phone } from "@lucide/astro";
import { Instagram, LinkedIn, Telegram, WhatsApp } from "~assets/icons";
import { HeroSmall } from "~assets/img";
import { Layout } from "~components";
import {
  Article,
  Button,
  Box,
  Flex,
  Grid,
  Heading,
  Image,
  Paragraph,
  Section,
} from "~components/ui";
---

<Layout title="CONTACTO :: ACH SYSTEMS">
  <Section class="py-16 lg:py-24 px-4 section-pattern">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 lg:mb-16 reveal">
        <Heading class="text-3xl md:text-4xl lg:text-5xl text-center mb-4 font-bold uppercase text-accent"
          >Contáctanos</Heading
        >
        <div class="w-24 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
        <p class="mt-6 text-neutral-600 max-w-2xl mx-auto text-lg">
          Estamos listos para ayudarte a transformar tu negocio con soluciones tecnológicas personalizadas
        </p>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="order-2 lg:order-1 reveal-left">
          <Box class="bg-white rounded-2xl p-6 lg:p-8 shadow-xl border border-transparent hover:border-accent/20 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="p-2 bg-accent/10 rounded-lg">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <Heading as="h2" class="text-xl lg:text-2xl font-bold text-neutral-800"
                >Envíanos un mensaje</Heading
              >
            </div>
            <form
              action="https://formspree.io/f/xkgbrojp"
              method="POST"
              class="flex flex-col gap-5"
            >
              <div class="relative">
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="name"
                  >Nombre completo o empresa</label
                >
                <input
                  id="name"
                  name="Nombre completo o nombre de la empresa"
                  type="text"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all bg-neutral-50"
                  required
                  placeholder="Tu nombre o el de tu empresa"
                />
              </div>

              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-2" for="email"
                    >Correo electrónico</label
                  >
                  <input
                    id="email"
                    name="Correo electrónico"
                    type="email"
                    class="w-full px-4 py-3 rounded-lg border border-neutral-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all bg-neutral-50"
                    required
                    placeholder="correo@ejemplo.com"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-2" for="phone"
                    >Teléfono</label
                  >
                  <input
                    id="phone"
                    name="Número de teléfono"
                    type="tel"
                    class="w-full px-4 py-3 rounded-lg border border-neutral-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all bg-neutral-50"
                    required
                    placeholder="+58 412 123 4567"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-3"
                  >¿Qué tipo de sistema necesitas?</label
                >
                <div class="grid md:grid-cols-2 gap-3">
                  {
                    [
                      "Sistema para Empresa",
                      "Sistema de Gestión",
                      "Sistema Médico",
                      "Sistema Administrativo",
                      "Otro / Asesoría",
                    ].map((option, optionIndex) => {
                      const id = `motive-${optionIndex + 1}`;
                      return (
                        <label for={id} class="flex items-center gap-3 cursor-pointer p-3 rounded-lg border border-neutral-200 hover:border-accent hover:bg-accent/5 transition-all">
                          <input
                            type="radio"
                            name="Motivo de solicitud"
                            id={id}
                            value={option}
                            class="radio radio-sm radio-accent"
                          />
                          <span class="text-sm text-neutral-700">{option}</span>
                        </label>
                      );
                    })
                  }
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-2" for="message"
                  >Cuéntanos sobre tu proyecto</label
                >
                <textarea
                  id="message"
                  name="Comentenos un poco más"
                  class="w-full px-4 py-3 rounded-lg border border-neutral-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all bg-neutral-50 h-40 resize-none"
                  placeholder="Describe brevemente qué necesitas para tu negocio..."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full bg-accent hover:bg-accent/90 text-white font-semibold py-4 px-6 rounded-lg transition-all hover:shadow-lg hover:-translate-y-1 flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Enviar mensaje
              </button>
            </form>
          </Box>
        </div>

        <div class="order-1 lg:order-2 flex flex-col gap-6 reveal-right">
          <Box class="bg-white rounded-2xl p-6 lg:p-8 shadow-xl border border-transparent hover:border-accent/20 transition-all duration-300">
            <div class="relative overflow-hidden rounded-xl mb-6">
              <Image
                src={HeroSmall}
                alt="ACH Systems - Contáctanos"
                loading="eager"
                class="w-full h-48 object-cover transform hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/70 to-transparent"></div>
              <div class="absolute bottom-4 left-4 text-white">
                <p class="font-bold text-lg">ACH Systems</p>
                <p class="text-sm text-white/80">Transformando negocios</p>
              </div>
            </div>
            
            <Heading as="h2" class="text-xl lg:text-2xl font-bold mb-6 text-neutral-800"
              >Escríbenos o llámanos</Heading
            >
            
            <div class="flex flex-col gap-4">
              <a
                href={`https://wa.me/584246375061`}
                class="flex items-center gap-4 p-4 rounded-xl border border-neutral-200 hover:border-accent hover:bg-accent/5 transition-all group"
              >
                <div class="p-3 bg-[#128c7e] rounded-xl group-hover:scale-110 transition-transform">
                  <WhatsApp class="size-6 fill-white" />
                </div>
                <div>
                  <p class="font-bold text-neutral-800">WhatsApp</p>
                  <p class="text-sm text-neutral-600">+58 424-637-5061</p>
                  <p class="text-xs text-accent mt-1">Respuesta inmediata</p>
                </div>
              </a>

              <a
                href="mailto:achsystems@hotmail.com"
                class="flex items-center gap-4 p-4 rounded-xl border border-neutral-200 hover:border-accent hover:bg-accent/5 transition-all group"
              >
                <div class="p-3 bg-primary rounded-xl group-hover:scale-110 transition-transform">
                  <Mail class="size-6 text-white" />
                </div>
                <div>
                  <p class="font-bold text-neutral-800">Email</p>
                  <p class="text-sm text-neutral-600">achsystems@hotmail.com</p>
                  <p class="text-xs text-accent mt-1">Respondemos en 24h</p>
                </div>
              </a>
            </div>

            <div class="mt-8 pt-6 border-t border-neutral-200">
              <p class="font-semibold text-neutral-700 mb-4">Síguenos en redes</p>
              <Grid class="grid-cols-4 gap-3">
                <a 
                  target="_blank" 
                  href="https://www.instagram.com/achsystems"
                  class="p-4 bg-gradient-to-tr from-yellow-500 via-pink-600 to-blue-500 rounded-xl flex justify-center hover:scale-110 hover:shadow-lg transition-all"
                >
                  <Instagram class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://wa.me/584246375061"
                  class="p-4 bg-[#128c7e] rounded-xl flex justify-center hover:scale-110 hover:shadow-lg transition-all"
                >
                  <WhatsApp class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://www.linkedin.com/in/ach-systems-2025-4146700191-/"
                  class="p-4 bg-[#0a66c2] rounded-xl flex justify-center hover:scale-110 hover:shadow-lg transition-all"
                >
                  <LinkedIn class="size-6 fill-white" />
                </a>
                <a 
                  target="_blank" 
                  href="https://t.me/achsystems"
                  class="p-4 bg-[#0088cc] rounded-xl flex justify-center hover:scale-110 hover:shadow-lg transition-all"
                >
                  <Telegram class="size-6 fill-white" />
                </a>
              </Grid>
            </div>
          </Box>

          <Box class="bg-gradient-to-br from-primary to-secondary rounded-2xl p-6 lg:p-8 text-white">
            <Heading as="h3" class="text-xl font-bold mb-4"
              >Horario de atención</Heading
            >
            <div class="flex flex-col gap-2 text-white/80">
              <p class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Lunes a Viernes: 8:00 AM - 8:00 PM
              </p>
              <p class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Sábados: 9:00 AM - 5:00 PM
              </p>
            </div>
            <div class="mt-6 pt-4 border-t border-white/20">
              <p class="text-sm text-white/70">
                * Las asesorías técnicas puedenprogramarse fuera del horario habitual
              </p>
            </div>
          </Box>
        </div>
      </div>
    </div>
  </Section>

  <Section class="bg-neutral-100 py-16 lg:py-24 section-pattern">
    <div class="max-w-4xl mx-auto text-center px-4 reveal-scale">
      <Heading class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6 text-neutral-800"
        >¿Prefieres una llamada directa?</Heading
      >
      <Paragraph class="text-lg mb-8 text-neutral-600 max-w-2xl mx-auto">
       Nuestro equipo está listo para evaluar tu proyecto sin compromiso. Cuéntanos sobre tu necesidad y te contactaremos pronto.
      </Paragraph>
      <a 
        href="https://wa.me/584246375061"
        class="inline-flex items-center gap-3 bg-accent hover:bg-accent/90 text-white font-semibold py-4 px-10 rounded-full transition-all hover:shadow-lg hover:-translate-y-1"
      >
        <WhatsApp class="size-6 fill-white" />
        <span class="text-lg">Escríbenos por WhatsApp</span>
      </a>
    </div>
  </Section>
</Layout>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
    observer.observe(el);
  });
</script>
