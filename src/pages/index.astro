---
import {
  ChartLine,
  ClipboardPlus,
  Palette,
  Pencil,
  Save,
  ShoppingCart,
  SquareStack,
  Stethoscope,
} from "@lucide/astro";
import {
  Hero,
  HomeAside1,
  HomeAside2,
  HomeAside3,
  HomeAside4,
} from "~assets/img";
import { Layout } from "~components";
import {
  Article,
  Aside,
  Box,
  Button3D,
  Flex,
  Grid,
  Heading,
  Image,
  Paragraph,
  Section,
  Text,
} from "~components/ui";

const services = [
  {
    title: "Sistemas de Gestión",
    icon: ChartLine,
    description:
      "Brindamos una solución ideal para que usted inicie su recorrido en esta nueva era digital, con sistemas únicos para la gestión de su comercio, brindando confort y aumentando la productividad.",
  },
  {
    title: "Sistemas Personalizados",
    icon: Save,
    description:
      "Nuestro equipo está capacitado para diseñarle sistemas a la medida, totalmente exclusivos y adaptados a los conocimientos de sus empleados, otorgándole manejabilidad y adaptabilidad.",
  },
  {
    title: "Diseño de Sistemas",
    icon: Pencil,
    description:
      "Contamos con especialistas en diseño y análisis de sistemas, permitiéndole a usted tener un proyecto único, proporcionando funcionalidad y apariencia acordes a su labor, sin descuidar la identidad organizativa.",
  },
  {
    title: "Asesorías Gratuitas",
    icon: Palette,
    description:
      "Si usted no posee conocimientos en referencia a los requerimientos necesarios para automatizar su organización, puede solicitar ahora mismo una visita totalmente gratuita. Nuestros asesores están complacidos de aclarar sus preguntas.",
  },
  {
    title: "Sistemas para Historias Médicas",
    icon: ClipboardPlus,
    description:
      "Contamos con personal capacitado en el área de la salud, los cuales pueden brindarle soluciones ideales para optimizar sus labores diarias, además realizamos sistemas dedicados exclusivamente para la elaboración de historias médicas.",
  },
  {
    title: "Sistemas para Consultorios Médicos",
    icon: Stethoscope,
    description:
      "Conocemos la importancia de mantener un correcto registro para facilitar la atención a sus pacientes, por ello diseñamos sistemas según su especialidad médica permitiéndole a usted contar con un registro automatizado de sus servicios.",
  },
  {
    title: "Sistemas Administrativos",
    icon: SquareStack,
    description:
      "¿Su empresa pertenece al comercio informal y desea llevar el registro de sus ventas?  Contamos con proyectos ideales para ello,  nos adaptamos al tamaño de su comercio y diseñamos sistemas administrativos simples y manejables.",
  },
  {
    title: "Sistemas para Emprendedores",
    icon: ShoppingCart,
    description:
      "Si eres emprendedor y estás iniciando en el mundo digital, tenemos sistemas ideales para ti, puedes tener tu negocio Online basado en plantillas pre diseñadas  y así impulsarte al siguiente nivel, adaptándonos a tu presupuesto.",
  },
];
---

<Layout>
  <Section class="p-0">
    <div class="relative w-full h-[70vh] md:h-[calc(100vh-70px)] overflow-hidden">
      <Image
        src={Hero}
        alt="ACH Systems - Soluciones tecnológicas para tu negocio"
        loading="eager"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/50 to-transparent"></div>
      <div class="absolute inset-0 hero-pattern opacity-30"></div>
      <div class="absolute bottom-0 left-0 right-0 flex flex-col items-center justify-center px-4 py-16 text-center">
        <h1 class="text-white text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-wider drop-shadow-xl animate-fade-in-up">
          Transformamos tu negocio
        </h1>
        <p class="text-white/90 text-lg md:text-xl mt-4 max-w-3xl drop-shadow-md animate-fade-in-up" style="animation-delay: 200ms">
          Soluciones tecnológicas personalizadas que impulsan tu productividad y eficiencia
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-8 animate-fade-in-up" style="animation-delay: 400ms">
          <a href="/contacto/" class="bg-accent hover:bg-accent/90 text-white font-semibold px-8 py-3 rounded-full transition-all hover:shadow-lg hover:shadow-accent/30 hover:-translate-y-1">
            Cotizar proyecto
          </a>
          <a href="/proyectos/" class="border-2 border-white text-white hover:bg-white hover:text-primary font-semibold px-8 py-3 rounded-full transition-all hover:-translate-y-1">
            Ver proyectos
          </a>
        </div>
      </div>
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-8 h-8 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </Section>

  <Section class="py-16 lg:py-24 px-4 section-pattern">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 lg:mb-16 reveal">
        <Heading
          class="text-accent pb-4 text-3xl md:text-4xl lg:text-5xl font-bold uppercase"
          transition:name="services-title"
        >
          Nuestros Servicios
        </Heading>
        <div class="w-24 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
        <p class="mt-6 text-neutral-600 max-w-2xl mx-auto text-lg">
          Soluciones tecnológicas integrales diseñadas para transformar la gestión de tu negocio
        </p>
      </div>
      <div class="flex flex-col gap-6 lg:grid lg:grid-cols-2 lg:gap-8">
        {
          services.map((service, index) => (
            <Article 
              class="service-card group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-transparent hover:border-accent/20 relative overflow-hidden"
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -translate-y-1/2 translate-x-1/2 group-hover:scale-150 transition-transform duration-500"></div>
              <Flex class="mb-4 flex-row items-center gap-4">
                <div class="p-3 bg-accent/10 rounded-xl group-hover:bg-accent group-hover:text-white transition-all duration-300">
                  {service.icon && <service.icon class="size-7 md:size-8 text-accent group-hover:text-white" />}
                </div>
                <Heading as="h3" class="text-xl lg:text-2xl font-bold text-neutral-800">{service.title}</Heading>
              </Flex>
              <Paragraph class="text-neutral-600 leading-relaxed text-base lg:text-lg">{service.description}</Paragraph>
              <div class="mt-4 pt-4 border-t border-neutral-100 flex items-center text-accent font-medium opacity-0 group-hover:opacity-100 transition-opacity">
                <span>Más información</span>
                <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </Article>
          ))
        }
      </div>
    </div>
  </Section>

  <Section class="bg-primary py-16 lg:py-24 text-white relative overflow-hidden">
    <div class="absolute inset-0 hero-pattern opacity-20"></div>
    <Box class="relative max-w-4xl mx-5 rounded-2xl p-1 gradient-border">
      <Box class="bg-secondary/90 backdrop-blur-sm rounded-xl p-8 lg:p-12">
        <Flex class="flex-col justify-center text-center gap-6">
          <Heading class="text-3xl md:text-4xl lg:text-5xl font-bold">
            ¿Listo para transformar tu negocio?
          </Heading>
          <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto">
            Contáctanos hoy y descubre cómo nuestras soluciones pueden impulsar tu productividad
          </p>
          <a href="/contacto/" class="flex justify-center mt-4">
            <Button3D>Agenda tu asesoría gratuita</Button3D>
          </a>
        </Flex>
      </Box>
    </Box>
  </Section>

  <Section class="flex flex-col justify-center py-16 lg:py-28 px-4">
    <Flex class="mb-12 flex-col gap-4 text-center">
      <Heading class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-800">
        ¿MIEDO AL <Text class="text-accent">CAMBIO</Text>?
      </Heading>
      <Heading class="text-accent text-4xl md:text-5xl lg:text-6xl font-light">O</Heading>
      <Heading class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-800">
        ¿MIEDO AL <Text class="text-accent">MEJORAR</Text>?
      </Heading>
    </Flex>
    <Article class="max-w-4xl mx-auto mb-16 px-4">
      <div class="bg-neutral-50 rounded-2xl p-8 lg:p-12 border-l-4 border-accent">
        <Paragraph class="mb-6 text-lg md:text-xl leading-relaxed text-neutral-700">
          Una empresa productiva no puede detenerse, pero esto no significa que deba stagnar. El miedo a adaptarse rápidamente al nuevo método de gestión es común, pero no tiene por qué ser un obstáculo.
        </Paragraph>
        <Paragraph class="text-lg md:text-xl leading-relaxed text-neutral-700">
          Contamos con especialistas en diseños simples, únicos y adaptados a su medida. Nuestro soporte personalizado y sistemas intuitivos están diseñados para usuarios con mínima experiencia tecnológica, permitiéndole ahorrar costos, reducir tiempos de espera y aumentar la eficiencia de su negocio.
        </Paragraph>
      </div>
    </Article>
    <a href="/contacto/" class="flex justify-center">
      <Button3D color="bg-neutral-700" class="text-white px-10 py-5 text-xl"
        >¡Quiero automatizar mi negocio!</Button3D
      >
    </a>
  </Section>

  <Section class="relative h-[60vh] md:h-[70vh] lg:h-[80vh] overflow-hidden">
    <Box
      class:list={[
        "parallax-bg",
        "absolute inset-0 flex w-auto items-center justify-center bg-[url('../src/assets/img/home/bg1.webp')] bg-cover bg-fixed bg-center bg-no-repeat",
      ]}
    />
    <div class="absolute inset-0 bg-primary/70"></div>
    <div class="absolute inset-0 hero-pattern opacity-30"></div>
    <Flex class="relative z-10 mx-4 md:mx-10 items-center justify-center h-full">
      <div class="text-center">
        <Heading class="text-2xl md:text-4xl lg:text-5xl text-white uppercase font-bold tracking-wide mb-4">
          <span class="bg-accent/90 px-6 py-3 rounded-lg"
            >EVITA PERDER EL ORDEN DE LAS HISTORIAS DE SUS PACIENTES</span
          >
        </Heading>
        <p class="text-white/80 text-lg md:text-xl max-w-3xl mx-auto mt-6">
          Digitaliza tu consultorio con sistemas especializados para el sector salud
        </p>
      </div>
    </Flex>
  </Section>

  <Section class="py-16 lg:py-24 px-4 section-pattern">
    <div class="px-4 lg:grid lg:grid-cols-2 items-center lg:gap-16 lg:px-10 max-w-6xl mx-auto">
      <Article class="flex flex-col justify-center mb-10 lg:mb-0 reveal-left">
        <span class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">Sector Salud</span>
        <Heading class="mb-6 text-center leading-tight text-2xl md:text-3xl lg:text-4xl font-bold text-neutral-800"
          ><span class="text-neutral-600">"</span>Las <Text class="text-accent">historias médicas manuales</Text> son más sencillo<span class="text-neutral-600">"</span></Heading
        >
        <Paragraph class="mb-6 text-lg leading-relaxed text-neutral-600"
          >Contamos con un equipo especializado en el diseño de sistemas
          totalmente accesibles para el personal de salud, especialmente en
          formatos para historias médicas según la especialidad. Nuestros trabajos han sido presentados en el Congreso
          de Ingenieros Zulia 2024 "Ing. Emilio López".</Paragraph
        >
        <Paragraph class="mb-8 text-center text-lg font-semibold text-accent"
          >¿Desea conocerlo?</Paragraph
        >
        <a href="/proyectos/" class="flex justify-center">
          <Button3D color="bg-accent" class="text-white">Ver proyectos de salud</Button3D>
        </a>
      </Article>
      <Aside class="flex flex-col gap-6 reveal-right">
        <div class="relative overflow-hidden rounded-2xl group">
          <Image
            src={HomeAside1}
            alt="Sistema médico ACH Systems - Interfaz profesional"
            loading="eager"
            class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
          <div class="absolute bottom-4 left-4 text-white">
            <p class="font-semibold">Gestión de Pacientes</p>
          </div>
        </div>
        <Image
          src={HomeAside2}
          alt="Gestión de historias médicas digitales"
          loading="eager"
          class="w-full rounded-2xl shadow-xl hover:shadow-2xl transition-shadow duration-300"
        />
      </Aside>
    </div>
  </Section>

  <Section class="relative h-[50vh] md:h-[60vh] lg:h-[70vh] overflow-hidden">
    <Box
      class:list={[
        "parallax-bg",
        "absolute inset-0 flex w-auto items-center justify-center bg-[url('../src/assets/img/home/bg2.webp')] bg-cover bg-fixed bg-center bg-no-repeat",
      ]}
    />
    <div class="absolute inset-0 bg-primary/70"></div>
    <div class="absolute inset-0 hero-pattern opacity-30"></div>
    <Flex class="relative z-10 mx-2 md:mx-10 flex-col items-center justify-center gap-6 md:gap-8 h-full">
      <Heading class="text-center text-2xl md:text-4xl lg:text-5xl text-white uppercase font-bold tracking-wide">
        <span class="bg-primary/80 px-6 py-3 rounded-lg">EVITA EL DESASTRE EN PAPEL</span>
      </Heading>
      <Heading class="text-center text-2xl md:text-4xl lg:text-5xl text-white uppercase font-bold tracking-wide">
        <span class="bg-accent px-8 py-4 rounded-lg">&lt;&lt; AUTOMATÍZATE YA &gt;&gt;</span>
      </Heading>
    </Flex>
  </Section>

  <Section class="py-16 lg:py-24 px-4 section-pattern">
    <div class="px-4 lg:grid lg:grid-cols-2 items-center lg:gap-16 lg:px-10 max-w-6xl mx-auto">
      <Aside class="order-2 lg:order-1 reveal-left"
        ><Image
          src={HomeAside3}
          alt="Sistema administrativo para comercios"
          loading="eager"
          class="w-full rounded-2xl shadow-2xl mb-8 lg:mb-0 hover:shadow-accent/20 transition-all duration-300"
        />
      </Aside>
      <Article class="order-1 lg:order-2 flex flex-col justify-center reveal-right">
        <span class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">Comercio y Empresas</span>
        <Heading class="mb-6 text-center leading-tight text-2xl md:text-3xl lg:text-4xl font-bold text-neutral-800">
          <span class="text-neutral-600">"</span>Tengo un comercio y deseo un <Text class="text-accent">sistema de recibos e inventarios</Text><span class="text-neutral-600">"</span>
        </Heading>
        <Paragraph class="mb-8 text-lg leading-relaxed text-neutral-600">
          La mayoría de los software administrativos tienen cientos de funcionalidades confusas que no se adaptan a pequeños comercios. Nosotros desarrollamos sistemas a la medida de tu negocio que generan un entorno productivo y eficaz. Nuestros ingenieros adaptarán módulos ideales para su nivel de manejabilidad.
        </Paragraph>
        <a href="/contacto/" class="flex justify-center">
          <Button3D color="bg-accent" class="text-white">Solicitar cotización</Button3D>
        </a>
      </Article>
    </div>
  </Section>

  <Section class="relative h-[50vh] md:h-[60vh] lg:h-[70vh] overflow-hidden">
    <Box
      class:list={[
        "parallax-bg",
        "absolute inset-0 flex w-auto items-center justify-center bg-[url('../src/assets/img/home/bg3.webp')] bg-cover bg-fixed bg-center",
      ]}
    />
    <div class="absolute inset-0 bg-primary/80"></div>
    <div class="absolute inset-0 hero-pattern opacity-30"></div>
    <Flex class="relative z-10 mx-4 md:mx-10 items-center justify-center h-full">
      <div class="text-center max-w-4xl">
        <Heading class="text-xl md:text-3xl lg:text-4xl text-white uppercase font-bold tracking-wide mb-4">
          <span class="bg-primary/80 px-6 py-3 rounded-lg"
            >¿TIENES DIFICULTAD PARA USAR LAS FUNCIONES BÁSICAS DE TU TELÉFONO?
          </span>
        </Heading>
        <p class="text-white/80 text-lg md:text-xl mt-6">
          No te preocupes. Nuestros sistemas están diseñados para ser intuitivos y fáciles de usar
        </p>
      </div>
    </Flex>
  </Section>

  <Section class="bg-neutral-100 py-16 lg:py-24 section-pattern">
    <div class="max-w-4xl mx-auto text-center px-4 reveal-scale">
      <Heading class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-800 mb-6"
        >¿Entonces?... ¿Qué esperas?</Heading
      >
      <Heading class="text-3xl md:text-4xl lg:text-5xl text-accent italic mb-8"
        >Tan fácil como usar tu celular.</Heading
      >
      <Heading class="text-3xl md:text-4xl font-bold text-neutral-700 mb-10">¿Aún no te decides?</Heading>
      <a href="/contacto/" class="inline-block">
        <Button3D color="bg-accent text-white px-12 py-5 text-xl"
          >SOLICITA TU ASESORÍA</Button3D
        >
      </a>
    </div>
  </Section>

  <Section class="py-16 lg:py-24 px-4">
    <div class="px-4 lg:grid lg:grid-cols-2 items-center lg:gap-16 lg:px-10 max-w-6xl mx-auto">
      <Article class="flex flex-col justify-center mb-10 lg:mb-0 reveal-left">
        <span class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">Asesoría Gratis</span>
        <Heading class="mb-6 text-center leading-tight text-2xl md:text-3xl lg:text-4xl font-bold text-neutral-800"
          ><span class="text-neutral-600">"</span>No tengo idea de lo que necesito<Text class="text-accent"
          > para automatizar</Text><span class="text-neutral-600">"</span></Heading
        >
        <Paragraph class="mb-8 text-lg leading-relaxed text-neutral-600">
          ¡No se preocupe! Brindamos asesoría gratuita. Solo complete el
          formulario de contacto para agendar una visita técnica. Un ingeniero capacitado evaluará su negocio para determinar los requerimientos ideales para un sistema adaptado a sus necesidades.
        </Paragraph>
        <a href="/contacto/" class="flex justify-center">
          <Button3D color="bg-accent" class="text-white">Contáctanos</Button3D>
        </a>
      </Article>
      <Aside class="reveal-right"
        ><Image
          src={HomeAside4}
          alt="Equipo ACH Systems - Expertos en tecnología"
          loading="eager"
          class="w-full rounded-2xl shadow-2xl hover:shadow-accent/20 transition-all duration-300"
        />
      </Aside>
    </div>
  </Section>
</Layout>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
    observer.observe(el);
  });

  window.addEventListener("scroll", function () {
    const parallaxElements = document.querySelectorAll(".parallax-bg");
    parallaxElements.forEach((element) => {
      let scrollPosition = window.pageYOffset;
      (element as HTMLElement).style.backgroundPosition =
        `center ${scrollPosition * 0.005}px`;
    });
  });
</script>
