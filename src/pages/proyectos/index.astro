---
import {
  sistemaHistorialMedicoLosOlivosThumb,
  sistemaWebLaboratorioHinestrozaFerrerThumb,
  sistemaRecibos2Tasas2MonedasSireThumb,
} from "~assets/img";
import { Layout } from "~components";
import { Box, Flex, Grid, Heading, Image } from "~components/ui";
---

<Layout
  title="Portafolio de Proyectos | ACH Systems"
  description="Explora el portafolio de ACH Systems con proyectos reales de sistemas para historial médico, laboratorios y gestión administrativa."
  keywords="portafolio de software, casos de exito, sistema historial medico, sistema administrativo"
>
  <Box class="mx-auto w-full max-w-7xl p-4 sm:px-6 lg:px-8 lg:py-8">
    <Heading as="h2" class="pb-2 text-center text-primary"
      >Nuestro portafolio de proyectos</Heading
    >
    <p class="mx-auto mb-6 max-w-3xl text-center text-sm text-slate-600 sm:text-base">
      Conoce implementaciones reales enfocadas en productividad, simplicidad de uso y control operativo.
    </p>
    <Flex class="mb-8 w-full border-t border-dashed border-neutral-400" />
    <Grid
      class:list={[
        "gap-4 sm:gap-5",
        "sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4",
      ]}
      data-stagger
    >
      <a href="./sistema-web-laboratorio-hinestroza-ferrer/">
        <div
          class="surface-card flex h-full min-h-84 w-full flex-col items-center gap-y-4 overflow-hidden rounded-2xl p-3 text-center transition-all duration-250 hover:-translate-y-1"
        >
          <figure>
            <Image
              src={sistemaWebLaboratorioHinestrozaFerrerThumb}
              alt=""
              class="h-44 w-full max-w-xs rounded-xl object-cover"
            />
          </figure>
          <h2 class="text-lg font-semibold text-primary sm:text-xl">
            Sistema de Información Web para la Gestión de Servicios en el
            Clínico Hinestroza Ferrer C.A
          </h2>
        </div>
      </a>
      <a href="./sistema-recibos-2-tasas-2-monedas-sire/">
        <div
          class="surface-card flex h-full min-h-84 w-full flex-col items-center gap-y-4 overflow-hidden rounded-2xl p-3 text-center transition-all duration-250 hover:-translate-y-1"
        >
          <figure>
            <Image
              src={sistemaRecibos2Tasas2MonedasSireThumb}
              alt=""
              class="h-44 w-full max-w-xs rounded-xl object-cover"
            />
          </figure>
          <h2 class="text-lg font-semibold text-primary sm:text-xl">
            Sistema de Recibos 2 Tasas 2 Monedas SIRE 2T
          </h2>
        </div>
      </a>
      <a href="./sistema-historial-medico-los-olivos/">
        <div
          class="surface-card flex h-full min-h-84 w-full flex-col items-center gap-y-4 overflow-hidden rounded-2xl p-3 text-center transition-all duration-250 hover:-translate-y-1"
        >
          <figure>
            <Image
              src={sistemaHistorialMedicoLosOlivosThumb}
              alt=""
              class="h-44 w-full max-w-xs rounded-xl object-cover"
            />
          </figure>
          <h2 class="text-lg font-semibold text-primary sm:text-xl">
            Sistema de Historial Médico - Centro Clínico Los Olivos
          </h2>
        </div>
      </a>
    </Grid>
  </Box>
</Layout>
