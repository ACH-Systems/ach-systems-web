---
import { Clock, Mail, Menu, X } from "@lucide/astro";
import { Image } from "astro:assets";
import { Instagram, LinkedIn, WhatsApp } from "~assets/icons";
import { Logo } from "~assets/img";
import { navItems } from "./navItems";

const EMAIL_ADDRESS = "achsystems@hotmail.com";
const PHONE_NUMBER = "+58 424-637-5061";

const currentPath = Astro.url.pathname;
---

<div class="fixed z-5 w-full">
  <header
    class:list={[
      "bg-primary/100 transition-bg flex w-full flex-col text-white shadow-lg backdrop-blur-[3px] duration-200",
    ]}
    transition:animate="none"
  >
    <div
      class="bg-secondary relative overflow-hidden border-b-1 border-neutral-500 px-3 lg:px-6 py-1.5 text-white"
    >
      <div
        class="absolute inset-0 z-0 opacity-20 bg-[url('../src/assets/img/pattern.png')]"
      >
      </div>
      <div class="relative z-1 flex items-center justify-between">
        <div class="flex flex-row items-center">
          <Clock class="mr-2 size-4 md:size-5 text-accent" />
          <span class="text-xs font-medium">Atención: 8 AM - 8 PM</span>
        </div>
        <div class="flex flex-row items-center gap-3 md:gap-4">
          <a
            aria-label="WhatsApp"
            href={`https://wa.me/${PHONE_NUMBER.replace(/\s|-/g, "")}`}
            class="flex flex-row items-center hover:text-accent transition-colors duration-200"
          >
            <WhatsApp class:list={["m-0 size-4 md:size-5 fill-white", "hover:fill-accent"]} />
            <span class:list={["hidden text-xs ml-1", "md:block"]}
              >{PHONE_NUMBER}</span
            >
          </a>
          <a
            aria-label="E-mail"
            href={`mailto:${EMAIL_ADDRESS}`}
            class="flex flex-row items-center hover:text-accent transition-colors duration-200"
          >
            <Mail class="m-0 size-4 md:size-5" />
            <span class:list={["hidden text-xs ml-1", "md:block"]}
              >{EMAIL_ADDRESS}</span
            >
          </a>
          <div
            class:list={[
              "mx-1 hidden h-5 border-l border-dotted border-white/50",
              "md:block",
            ]}
          >
          </div>
          <div class:list={["flex gap-2", "md:gap-3"]}>
            <a
              aria-label="Instagram"
              href="https://www.instagram.com/achsystems"
              class="flex flex-row items-center hover:text-accent transition-colors duration-200"
            >
              <Instagram class:list={["m-0 size-4 md:size-5 fill-white", "hover:fill-accent"]} />
            </a>
            <a
              aria-label="LinkedIn"
              href="https://www.linkedin.com/in/ach-systems-2025-4146700191-/"
              class="flex flex-row items-center hover:text-accent transition-colors duration-200"
            >
              <LinkedIn class:list={["m-0 size-4 md:size-5 fill-white", "hover:fill-accent"]} />
            </a>
          </div>
        </div>
      </div>
    </div>
    <div
      class:list={[
        "flex flex-wrap justify-between px-4 py-2",
        "md:px-10 lg:px-20 xl:px-40 2xl:px-80",
      ]}
    >
      <div class:list={["flex w-10", "md:hidden"]}></div>
      <a href="/" class="transition-transform duration-300 hover:scale-105 inline-block">
        <Image
          src={Logo}
          alt="ACH Systems - Inicio"
          loading="eager"
          class:list={["w-20 md:w-24 lg:w-28 self-center py-2"]}
        />
      </a>
      <div
        class:list={[
          "hidden flex-row flex-wrap items-center justify-center gap-1",
          "md:flex lg:gap-2",
        ]}
      >
        {
          navItems.slice(0, navItems.length - 1).map((item) => (
            <a
              draggable={false}
              href={item.path}
              class:list={[
                "shadow-accent group flex h-full flex-col items-center text-center transition-all duration-200 select-none relative",
                "active:bg-neutral-600/50",
              ]}
            >
              <span class="flex items-center px-4 lg:px-6 pt-8">
                <span
                  class:list={[
                    item.path === currentPath ? "mr-1.5 inline-block text-accent" : "hidden",
                  ]}
                >
                  &#9656;
                </span>
                <span class="text-sm lg:text-base font-medium">{item.name}</span>
              </span>
              <span
                class:list={[
                  "bg-accent mt-auto h-0.5 w-0 transition-all duration-300 group-hover:w-full",
                  item.path === currentPath ? "w-full" : "",
                  "group-active:bg-white",
                ]}
              />
            </a>
          ))
        }
        <div
          class:list={[
            "relative ml-2 lg:ml-3 cursor-pointer border-none bg-transparent p-0",
          ]}
        >
          <span
            class:list={[
              "bg-accent absolute top-0 left-0 h-full w-full rounded-full brightness-90",
            ]}></span>
          <a href="/contacto/">
            <button
              class:list={[
                "bg-accent relative block -translate-y-[5px] cursor-pointer rounded-full px-5 lg:px-6 py-2.5 lg:py-3 text-sm lg:text-base text-white transition-all duration-200 select-none font-semibold",
                "hover:-translate-y-[7px] hover:brightness-110",
                "active:-translate-y-1 active:duration-75",
              ]}
            >
              Contáctanos
            </button>
          </a>
        </div>
      </div>
      <button
        class:list={[
          "toggle-accordion",
          "m-1 p-2 rounded-lg transition-all duration-200",
          "hover:bg-white/10",
          "active:bg-neutral-500/50",
          "md:hidden",
        ]}
        aria-label="Menú"
      >
        <Menu class="size-7" />
      </button>
    </div>
  </header>
  <nav
    class:list={[
      "ease bg-primary/95 flex flex-col overflow-hidden border-t border-neutral-600 text-white shadow-xl backdrop-blur-sm",
      "md:hidden",
    ]}
    transition:animate="slide"
  >
    <div class="flex justify-end px-4 py-2 border-b border-neutral-700">
      <button
        class="close-accordion p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Cerrar menú"
      >
        <X class="size-6" />
      </button>
    </div>
    {
      navItems.map((item, index) => (
        <a
          href={item.path}
          draggable={false}
          class:list={[
            "block w-full border-dashed border-neutral-700 py-4 pl-6 text-lg font-medium transition-all duration-200 select-none",
            "hover:bg-white/10 hover:pl-8",
            "active:bg-neutral-600/50",
            "not-last:border-b",
          ]}
          style={`animation-delay: ${index * 50}ms`}
        >
          {item.name}
        </a>
      ))
    }
    <div class="p-6 border-t border-neutral-700 mt-2">
      <a
        href="/contacto/"
        class:list={[
          "block w-full text-center py-3 bg-accent rounded-lg font-semibold text-white",
          "hover:bg-accent/90 active:scale-95 transition-all duration-200",
        ]}
      >
        Contáctanos
      </a>
    </div>
  </nav>
</div>

<script>
  import { isAccordionOpen, isHeaderTransparent } from "../../stores";

  let nav = document.querySelector("nav");
  let header = document.querySelector("header");

  document.querySelector(".toggle-accordion")?.addEventListener("click", () => {
    isAccordionOpen.set(true);
  });

  document.querySelector(".close-accordion")?.addEventListener("click", () => {
    isAccordionOpen.set(false);
  });

  isAccordionOpen.subscribe((value) => {
    if (nav) {
      if (value) {
        nav.classList.remove("max-h-0");
        nav.classList.add("max-h-[500px]");
      } else {
        nav.classList.add("max-h-0");
        nav.classList.remove("max-h-[500px]");
      }
    }
    if (value) {
      header?.classList.add("bg-primary/100");
      header?.classList.remove("bg-primary/75");
      isHeaderTransparent.set(false);
    } else if (window.scrollY > 0 && !value) {
      header?.classList.add("bg-primary/100");
      header?.classList.remove("bg-primary/75");
      isHeaderTransparent.set(true);
    }
  });

  document.addEventListener("scroll", function () {
    if (window.scrollY > 0 && !isAccordionOpen.get()) {
      header?.classList.add("bg-primary/95");
      header?.classList.remove("bg-primary/100");
      isHeaderTransparent.set(true);
    } else {
      header?.classList.add("bg-primary/100");
      header?.classList.remove("bg-primary/95");
      isHeaderTransparent.set(false);
    }
  });

  header?.addEventListener("mouseenter", function () {
    if (isHeaderTransparent.get()) {
      header?.classList.add("bg-primary/100");
      header?.classList.remove("bg-primary/95");
    }
  });

  header?.addEventListener("mouseleave", function () {
    if (isHeaderTransparent.get()) {
      header?.classList.add("bg-primary/95");
      header?.classList.remove("bg-primary/100");
    }
  });
</script>
