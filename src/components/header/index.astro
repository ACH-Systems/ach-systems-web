---
import { Clock, Mail, Menu, Phone, X } from "@lucide/astro";
import { Image } from "astro:assets";
import { Instagram, LinkedIn, WhatsApp } from "~assets/icons";
import { Logo } from "~assets/img";
import { navItems } from "./navItems";

const EMAIL_ADDRESS = "achsystems@hotmail.com";
const PHONE_NUMBER = "+58 424-637-5061";
const whatsappUrl = `https://wa.me/${PHONE_NUMBER.replace(/\s|-/g, "")}`;
const currentPath = Astro.url.pathname;
---

<div class="fixed inset-x-0 top-0 z-50">
  <header
    id="site-header"
    class="bg-primary/95 flex w-screen flex-col border-b border-white/10 text-white shadow-xl shadow-slate-900/10 backdrop-blur-md transition-colors duration-300"
  >
    <div
      class="bg-secondary/95 relative overflow-hidden px-3 py-2 text-white/95"
    >
      <div
        class="absolute inset-0 z-0 bg-[url('../src/assets/img/pattern.png')] opacity-20"
      >
      </div>
      <div
        class="relative z-1 mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-x-3 gap-y-1 text-[0.67rem] sm:text-xs"
      >
        <div class="flex items-center gap-1.5">
          <Clock class="size-3.5 sm:size-4" />
          <span>Atención de 8 AM a 8 PM</span>
        </div>
        <div class="flex items-center gap-2 sm:gap-3">
          <a
            aria-label="WhatsApp"
            href={whatsappUrl}
            class="inline-flex items-center gap-1 sm:gap-1.5"
          >
            <WhatsApp class="size-3.5 fill-white sm:size-4" />
            <span class="hidden sm:inline">{PHONE_NUMBER}</span>
          </a>
          <a
            aria-label="E-mail"
            href={`mailto:${EMAIL_ADDRESS}`}
            class="inline-flex items-center gap-1 sm:gap-1.5"
          >
            <Mail class="size-3.5 sm:size-4" />
            <span class="hidden lg:inline">{EMAIL_ADDRESS}</span>
          </a>
          <div
            class="mx-1 hidden h-4 border-l border-dotted border-white/50 sm:block"
          >
          </div>
          <a
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.instagram.com/achsystems"
            class="inline-flex items-center"
          >
            <Instagram class="size-3.5 fill-white sm:size-4" />
          </a>
          <a
            aria-label="LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.linkedin.com/in/ach-systems-2025-4146700191-/"
            class="inline-flex items-center"
          >
            <LinkedIn class="size-3.5 fill-white sm:size-4" />
          </a>
        </div>
      </div>
    </div>

    <div
      class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8"
    >
      <a href="/" class="inline-flex shrink-0 items-center">
        <Image
          src={Logo}
          alt="ACH systems"
          loading="eager"
          class="w-24 sm:w-28"
        />
      </a>

      <nav class="hidden items-center gap-1 md:flex lg:gap-2">
        {
          navItems.slice(0, navItems.length - 1).map((item) => (
            <a
              draggable={false}
              href={item.path}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-semibold tracking-wide transition-all duration-200",
                "hover:bg-white/12 hover:text-white",
                item.path === currentPath
                  ? "text-primary bg-white"
                  : "text-white/90",
              ]}
            >
              {item.name}
            </a>
          ))
        }
        <a
          href="/contacto/"
          class="bg-accent text-primary ml-2 inline-flex items-center rounded-full px-6 py-2.5 text-sm font-bold shadow-lg shadow-amber-500/30 transition-all duration-250 hover:-translate-y-0.5 hover:brightness-110"
        >
          Contáctanos
        </a>
      </nav>

      <button
        class="toggle-accordion inline-flex cursor-pointer rounded-xl border border-white/20 p-2.5 text-white transition-all duration-200 hover:bg-white/12 active:scale-95 md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <Menu class="menu-icon size-7" />
        <X class="close-icon hidden size-7" />
      </button>
    </div>
  </header>

  <nav
    id="mobile-nav"
    class="bg-primary flex max-h-0 flex-col overflow-hidden border-b border-white/10 text-white opacity-0 transition-all duration-300 md:hidden"
  >
    <div class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-4 py-4">
      {
        navItems.map((item) => (
          <a
            href={item.path}
            draggable={false}
            class:list={[
              "block w-full rounded-xl border border-white/15 px-4 py-3 text-left text-base font-semibold tracking-wide transition-all duration-200",
              "active:scale-[0.99]",
              item.path === currentPath
                ? "text-primary bg-white"
                : "bg-white/6 text-white/90",
            ]}
          >
            {item.name}
          </a>
        ))
      }
      <a
        href={whatsappUrl}
        class="bg-accent text-primary mt-2 inline-flex items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-bold"
      >
        <Phone class="size-4" />
        Escríbenos por WhatsApp
      </a>
    </div>
  </nav>
</div>

<script>
  import { isAccordionOpen, isHeaderTransparent } from "../../stores";

  const nav = document.querySelector("#mobile-nav");
  const header = document.querySelector("#site-header");
  const toggleButton = document.querySelector(".toggle-accordion");
  const menuIcon = toggleButton?.querySelector(".menu-icon");
  const closeIcon = toggleButton?.querySelector(".close-icon");
  const isMdScreen = window.matchMedia("(min-width: 768px)");

  function updateHeaderOnScroll() {
    if (!header) return;
    const shouldBeTransparent = window.scrollY > 10 && !isAccordionOpen.get();
    if (shouldBeTransparent) {
      header.classList.remove("bg-primary/95");
      header.classList.add("bg-primary/80");
    } else {
      header.classList.remove("bg-primary/80");
      header.classList.add("bg-primary/95");
    }
    isHeaderTransparent.set(shouldBeTransparent);
  }

  function syncMenuState(open) {
    if (!nav) return;
    nav.classList.toggle("max-h-96", open);
    nav.classList.toggle("max-h-0", !open);
    nav.classList.toggle("opacity-100", open);
    nav.classList.toggle("opacity-0", !open);

    menuIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
    toggleButton?.setAttribute("aria-expanded", String(open));
  }

  toggleButton?.addEventListener("click", () => {
    isAccordionOpen.set(!isAccordionOpen.get());
  });

  isAccordionOpen.subscribe((value) => {
    syncMenuState(value);
    updateHeaderOnScroll();
  });

  document.addEventListener("scroll", updateHeaderOnScroll, { passive: true });
  updateHeaderOnScroll();

  isMdScreen.addEventListener("change", () => {
    if (isMdScreen.matches) isAccordionOpen.set(false);
  });

  header?.addEventListener("mouseenter", () => {
    if (isHeaderTransparent.get()) {
      header.classList.remove("bg-primary/80");
      header.classList.add("bg-primary/95");
    }
  });

  header?.addEventListener("mouseleave", () => {
    if (isHeaderTransparent.get() && !isAccordionOpen.get()) {
      header.classList.remove("bg-primary/95");
      header.classList.add("bg-primary/80");
    }
  });
</script>
