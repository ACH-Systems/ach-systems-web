---
import { Instagram, LinkedIn,WhatsApp  } from "~assets/icons";
import { Image } from "astro:assets";
import { Logo } from "~assets/img";
import { Mail } from "@lucide/astro";

const currentYear = new Date().getFullYear();
---

<footer
  class:list={[
    "bg-primary z-3 flex flex-col items-center p-6 lg:p-10 text-white",
  ]}
>
  <div class="max-w-5xl w-full">
    <div class="grid md:grid-cols-3 gap-8 mb-10 text-center md:text-left">
      <div class="flex flex-col items-center md:items-start">
        <Image src={Logo} alt="ACH Systems" class="w-32 mb-4" />
        <p class="text-white/70 text-sm max-w-xs"
          >Innovación tecnológica para impulsar tu negocio. Sistemas personalizados 
          desarrollados en Venezuela.</p
        >
      </div>
      
      <div>
        <h4 class="font-bold text-lg mb-4 text-accent">Contacto</h4>
        <div class="flex flex-col gap-3">
          <a 
            href="https://wa.me/584246375061" 
            class="flex items-center gap-3 text-white/70 hover:text-white transition-colors text-sm"
          >
            <WhatsApp class="size-4" />
            <span>+58 424-637-5061</span>
          </a>
          <a 
            href="mailto:achsystems@hotmail.com" 
            class="flex items-center gap-3 text-white/70 hover:text-white transition-colors text-sm"
          >
            <Mail class="size-4" />
            <span>achsystems@hotmail.com</span>
          </a>
        </div>
      </div>
      
      <div>
        <h4 class="font-bold text-lg mb-4 text-accent">Síguenos</h4>
        <div class="flex justify-center md:justify-start gap-4">
          <a 
            href="https://www.instagram.com/achsystems" 
            target="_blank"
            aria-label="Instagram"
            class="p-2 bg-white/10 rounded-full hover:bg-accent transition-colors"
          >
            <Instagram class="size-5 fill-white" />
          </a>
          <a 
            href="https://www.linkedin.com/in/ach-systems-2025-4146700191-/" 
            target="_blank"
            aria-label="LinkedIn"
            class="p-2 bg-white/10 rounded-full hover:bg-accent transition-colors"
          >
            <LinkedIn class="size-5 fill-white" />
          </a>
          <a 
            href="https://wa.me/584246375061" 
            target="_blank"
            aria-label="WhatsApp"
            class="p-2 bg-white/10 rounded-full hover:bg-accent transition-colors"
          >
            <WhatsApp class="size-5 fill-white" />
          </a>
        </div>
      </div>
    </div>
    
    <div class="border-t border-white/10 pt-6 text-center">
      <p class="text-white/50 text-sm">
        © {currentYear} ACH SYSTEMS. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
